Uzupełnij aktualny ItemMap o te elementy:
'use client'

import ReservationBadge from '@/components/ReservationBadge'

import { useEffect, useRef, useState } from 'react'
import {
  MapContainer,
  TileLayer,
  Marker,
  Popup,
  useMap,
  useMapEvents,
} from 'react-leaflet'
import L from 'leaflet'
import 'leaflet/dist/leaflet.css'
import { supabase } from '@/lib/supabase'
import AddItemForm from '@/components/AddItemForm'
import AddPhotoModal from '@/components/AddPhotoModal'

type Item = {
  id: string
  title: string
  description: string | null
  category: string
  condition: string | null
  size: string | null
  latitude: number
  longitude: number
  status: string
  created_at: string
  expires_at: string
  distance_m: number
  image_urls: string[] | null
  reserved_until: string | null
  reserved_by: string | null
  taken_at: string | null
}

const defaultCenter: [number, number] = [52.4064, 16.9252]

const markerIcon = new L.Icon({
  iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
  shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
  iconSize: [25, 41],
  iconAnchor: [12, 41],
})

function MapClickHandler({
  onSelect,
}: {
  onSelect: (lat: number, lng: number) => void
}) {
  useMapEvents({
    click(e) {
      onSelect(e.latlng.lat, e.latlng.lng)
    },
  })

  return null
}

function MapFocusController({
  selectedItem,
}: {
  selectedItem: Item | null
}) {
  const map = useMap()

  useEffect(() => {
    if (!selectedItem) return

    map.flyTo([selectedItem.latitude, selectedItem.longitude], 16, {
      duration: 0.6,
    })
  }, [selectedItem, map])

  return null
}

function createItemIcon(imageUrl: string | null, status: string) {
  if (!imageUrl) return markerIcon

  return L.divIcon({
    className: '',
    html: 
      <div style="
        width: 46px;
        height: 46px;
        border-radius: 9999px;
        overflow: hidden;
        border: 3px solid ${status === 'reserved' ? '#f97316' : 'white'};
        box-shadow: 0 2px 8px rgba(0,0,0,0.35);
        background: white;
      ">
        <img
          src="${imageUrl}"
          style="
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
          "
        />
      </div>
    ,
    iconSize: [46, 46],
    iconAnchor: [23, 46],
    popupAnchor: [0, -46],
  })
}

function ItemPopup({
  item,
  deviceId,
  onAddPhoto,
  onRefresh,
}: {
  item: Item
  deviceId: string | null
  onAddPhoto: (itemId: string) => void
  onRefresh: () => Promise<void>
}) 
{
  const [imageIndex, setImageIndex] = useState(0)
  const images = item.image_urls ?? []
  const currentImage = images[imageIndex]
  const isReserved = item.status === 'reserved' && !!item.reserved_until
  const isMine = !!item.reserved_by && deviceId === item.reserved_by
  const [actionLoading, setActionLoading] = useState(false)
  
  return (
    <div className="w-56">
      <strong>{item.title}</strong>

      {currentImage ? (
        <div className="mt-2">
          <img
            src={currentImage}
            alt={item.title}
            className="h-32 w-full rounded object-cover"
          />

          {images.length > 1 && (
            <div className="mt-1 flex items-center justify-between text-xs">
              <button
                onClick={() =>
                  setImageIndex((prev) =>
                    prev === 0 ? images.length - 1 : prev - 1
                  )
                }
              >
                ◀
              </button>

              <span>
                {imageIndex + 1}/{images.length}
              </span>

              <button
                onClick={() =>
                  setImageIndex((prev) =>
                    prev === images.length - 1 ? 0 : prev + 1
                  )
                }
              >
                ▶
              </button>
            </div>
          )}
        </div>
      ) : (
        <div className="mt-2 flex h-32 w-full items-center justify-center rounded bg-gray-200 text-xs">
          Brak zdjęcia
        </div>
      )}

      <button
        className="mt-2 w-full rounded bg-gray-800 p-1 text-sm text-white"
        onClick={() => onAddPhoto(item.id)}
      >
        Dodaj zdjęcie
      </button>
{item.status === 'active' && (
  <button
    className="mt-2 w-full rounded bg-green-600 p-1 text-sm text-white active:scale-95 disabled:opacity-50"
    disabled={actionLoading || !deviceId}
    onClick={async () => {
      if (!deviceId) {
        alert('Nie udało się ustalić identyfikatora urządzenia')
        return
      }

      setActionLoading(true)

      const { error } = await supabase
        .from('items')
        .update({
          status: 'reserved',
          reserved_until: new Date(Date.now() + 30 * 60 * 1000).toISOString(),
          reserved_by: deviceId,
        })
        .eq('id', item.id)

      setActionLoading(false)

if (error) {
  console.error('RESERVATION ERROR:', error)
  alert(error.message)
  return
}
      await onRefresh()
	  alert('Zarezerwowano na 30 minut')
    }}
  >
    {actionLoading ? 'Rezerwuję...' : 'Rezerwuję na 30 min'}
  </button>
)}

{isReserved && !isMine && (
  <div className="mt-2 text-xs text-orange-600">
    Zarezerwowane do {new Date(item.reserved_until!).toLocaleTimeString()}
  </div>
)}

{isReserved && isMine && (
  <>
    <button
      className="mt-2 w-full rounded bg-blue-600 p-1 text-sm text-white"
      onClick={async () => {
        await supabase
          .from('items')
          .update({
            status: 'taken',
            taken_at: new Date().toISOString(),
          })
          .eq('id', item.id)

        onRefresh()
      }}
    >
      Odebrane
    </button>

    <button
      className="mt-2 w-full rounded bg-gray-500 p-1 text-sm text-white"
      onClick={async () => {
        await supabase
          .from('items')
          .update({
            status: 'active',
            reserved_until: null,
            reserved_by: null,
          })
          .eq('id', item.id)

        onRefresh()
      }}
    >
      Anuluj rezerwację
    </button>
  </>
)}
      <br />
      <span>{item.description}</span>
      <br />
      <small>Kategoria: {item.category}</small>
      <br />
      <small>Dystans: {Math.round(item.distance_m)} m</small>
    </div>
  )
}

export default function ItemsMap() {
  const [items, setItems] = useState<Item[]>([])
  const [loading, setLoading] = useState(true)
  const [uploadItemId, setUploadItemId] = useState<string | null>(null)
  const [selectedItem, setSelectedItem] = useState<Item | null>(null)
  const [onlyWithPhotos, setOnlyWithPhotos] = useState(false)
  const [deviceId, setDeviceId] = useState<string | null>(null)
  const [selectedLocation, setSelectedLocation] =
    useState<[number, number]>(defaultCenter)

  const markerRefs = useRef<Record<string, L.Marker | null>>({})
	const visibleItems = onlyWithPhotos
	  ? items.filter((item) => (item.image_urls?.length ?? 0) > 0)
	  : items
  
  async function loadItems() {
    setLoading(true)

    const { data, error } = await supabase.rpc('get_items_nearby', {
      user_lat: defaultCenter[0],
      user_lng: defaultCenter[1],
      radius_m: 3000,
    })

    if (error) {
      console.error(error)
      setLoading(false)
      return
    }

console.table(
  data?.map((item) => ({
    title: item.title,
    status: item.status,
    reserved_until: item.reserved_until,
    reserved_by: item.reserved_by,
  }))
)
    setItems(data ?? [])
    setLoading(false)
  }

  useEffect(() => {
    loadItems()
  }, [])

useEffect(() => {
  let id = localStorage.getItem('device_id')

  if (!id) {
    id = crypto.randomUUID()
    localStorage.setItem('device_id', id)
  }

  setDeviceId(id)
}, [])

  useEffect(() => {
    if (!selectedItem) return

    const marker = markerRefs.current[selectedItem.id]

    if (marker) {
      setTimeout(() => {
        marker.openPopup()
      }, 400)
    }
  }, [selectedItem])

  return (
    <div className="flex h-screen w-full">
      <div className="w-80 overflow-y-auto border-r bg-white">
        <div className="border-b p-3 font-bold">
          {loading ? 'Ładowanie...' : Znaleziono: ${visibleItems.length}}
        </div>
		<label className="flex items-center gap-2 border-b p-3 text-sm">
		  <input
			type="checkbox"
			checked={onlyWithPhotos}
			onChange={(e) => setOnlyWithPhotos(e.target.checked)}
		  />
		  Tylko ze zdjęciem
		</label>
        {visibleItems.map((item) => {
          const img = item.image_urls?.[0]

          return (
            <div
              key={item.id}
              className="cursor-pointer border-b p-2 hover:bg-gray-100"
              onClick={() => {
                setSelectedItem(item)
                setSelectedLocation([item.latitude, item.longitude])
              }}
            >
              {img ? (
                <img
                  src={img}
                  alt={item.title}
                  className="mb-1 h-24 w-full rounded object-cover"
                />
              ) : (
                <div className="mb-1 flex h-24 w-full items-center justify-center rounded bg-gray-200 text-xs">
                  Brak zdjęcia
                </div>
              )}

              <div className="flex items-center justify-between">
			  <div className="text-sm font-semibold">{item.title}</div>

			  {item.status === 'reserved' && (
				<span className="text-xs bg-orange-100 text-orange-700 px-2 py-0.5 rounded">
				  zarezerwowane
				</span>
			  )}
			</div>
              <div className="text-xs text-gray-500">
                {Math.round(item.distance_m)} m
              </div>
            </div>
          )
        })}
      </div>

      <div className="relative flex-1">
        <MapContainer
          center={defaultCenter}
          zoom={14}
          className="h-full w-full"
        >
          <TileLayer
            attribution="&copy; OpenStreetMap contributors"
            url="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
          />

          <MapFocusController selectedItem={selectedItem} />

          <MapClickHandler
            onSelect={(lat, lng) => setSelectedLocation([lat, lng])}
          />

          <Marker position={selectedLocation} icon={markerIcon}>
            <Popup>Nowe zgłoszenie tutaj</Popup>
          </Marker>

          {visibleItems.map((item) => (
            <Marker
              key={item.id}
              position={[item.latitude, item.longitude]}
              icon={createItemIcon(item.image_urls?.[0] ?? null, item.status)}
              ref={(ref) => {
                markerRefs.current[item.id] = ref
              }}
            >
              <Popup>
                <ItemPopup
				  item={item}
				  deviceId={deviceId}
				  onAddPhoto={(itemId) => setUploadItemId(itemId)}
				  onRefresh={loadItems}
				/>
              </Popup>
            </Marker>
          ))}
        </MapContainer>

        <AddItemForm
          onAdded={loadItems}
          latitude={selectedLocation[0]}
          longitude={selectedLocation[1]}
        />
      </div>

      {uploadItemId && (
        <AddPhotoModal
          itemId={uploadItemId}
          onClose={() => setUploadItemId(null)}
          onUploaded={loadItems}
        />
      )}
    </div>
  )
}

W tym kroku podmieniam głównie ItemPopup i lekko poprawiam feed, żeby korzystał z ReservationBadge. Dodałem też obsługę wygasłej rezerwacji jako dostępnej wizualnie.

Myślał przez kilka sekund
Poniżej masz podmieniony cały ItemsMap.tsx.

'use client'

import { useEffect, useRef, useState } from 'react'
import {
  MapContainer,
  TileLayer,
  Marker,
  Popup,
  useMap,
  useMapEvents,
} from 'react-leaflet'
import L from 'leaflet'
import 'leaflet/dist/leaflet.css'

import { supabase } from '@/lib/supabase'
import AddItemForm from '@/components/AddItemForm'
import AddPhotoModal from '@/components/AddPhotoModal'
import ReservationBadge from '@/components/ReservationBadge'
import { isReservationExpired } from '@/lib/reservationTime'

type Item = {
  id: string
  title: string
  description: string | null
  category: string
  condition: string | null
  size: string | null
  latitude: number
  longitude: number
  status: string
  created_at: string
  expires_at: string
  distance_m: number
  image_urls: string[] | null
  reserved_until: string | null
  reserved_by: string | null
  taken_at: string | null
}

const defaultCenter: [number, number] = [52.4064, 16.9252]

const markerIcon = new L.Icon({
  iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
  shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
  iconSize: [25, 41],
  iconAnchor: [12, 41],
})

function MapClickHandler({
  onSelect,
}: {
  onSelect: (lat: number, lng: number) => void
}) {
  useMapEvents({
    click(e) {
      onSelect(e.latlng.lat, e.latlng.lng)
    },
  })

  return null
}

function MapFocusController({ selectedItem }: { selectedItem: Item | null }) {
  const map = useMap()

  useEffect(() => {
    if (!selectedItem) return

    map.flyTo([selectedItem.latitude, selectedItem.longitude], 16, {
      duration: 0.6,
    })
  }, [selectedItem, map])

  return null
}

function createItemIcon(imageUrl: string | null, status: string) {
  if (!imageUrl) return markerIcon

  return L.divIcon({
    className: '',
    html: `
      <div style="
        width: 46px;
        height: 46px;
        border-radius: 9999px;
        overflow: hidden;
        border: 3px solid ${status === 'reserved' ? '#f97316' : 'white'};
        box-shadow: 0 2px 8px rgba(0,0,0,0.35);
        background: white;
      ">
        <img
          src="${imageUrl}"
          style="
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
          "
        />
      </div>
    `,
    iconSize: [46, 46],
    iconAnchor: [23, 46],
    popupAnchor: [0, -46],
  })
}

function ItemPopup({
  item,
  deviceId,
  onAddPhoto,
  onRefresh,
}: {
  item: Item
  deviceId: string | null
  onAddPhoto: (itemId: string) => void
  onRefresh: () => Promise<void>
}) {
  const [imageIndex, setImageIndex] = useState(0)
  const [actionLoading, setActionLoading] = useState(false)

  const images = item.image_urls ?? []
  const currentImage = images[imageIndex]

  const reservationExpired =
    item.status === 'reserved' && isReservationExpired(item.reserved_until)

  const effectiveStatus = reservationExpired ? 'active' : item.status

  const isReserved = effectiveStatus === 'reserved' && !!item.reserved_until
  const isMine = !!item.reserved_by && deviceId === item.reserved_by

  async function reserveItem() {
    if (!deviceId) {
      alert('Nie udało się ustalić identyfikatora urządzenia')
      return
    }

    setActionLoading(true)

    const { error } = await supabase
      .from('items')
      .update({
        status: 'reserved',
        reserved_until: new Date(Date.now() + 30 * 60 * 1000).toISOString(),
        reserved_by: deviceId,
      })
      .eq('id', item.id)

    setActionLoading(false)

    if (error) {
      console.error('RESERVATION ERROR:', error)
      alert(error.message)
      return
    }

    await onRefresh()
    alert('Zarezerwowano na 30 minut')
  }

  async function markAsTaken() {
    setActionLoading(true)

    const { error } = await supabase
      .from('items')
      .update({
        status: 'taken',
        taken_at: new Date().toISOString(),
      })
      .eq('id', item.id)

    setActionLoading(false)

    if (error) {
      console.error('TAKEN ERROR:', error)
      alert(error.message)
      return
    }

    await onRefresh()
  }

  async function cancelReservation() {
    setActionLoading(true)

    const { error } = await supabase
      .from('items')
      .update({
        status: 'active',
        reserved_until: null,
        reserved_by: null,
      })
      .eq('id', item.id)

    setActionLoading(false)

    if (error) {
      console.error('CANCEL RESERVATION ERROR:', error)
      alert(error.message)
      return
    }

    await onRefresh()
  }

  return (
    <div className="w-[240px]">
      {currentImage ? (
        <div className="relative mb-3 overflow-hidden rounded-xl">
          <img
            src={currentImage}
            alt={item.title}
            className="h-44 w-full object-cover"
          />

          {images.length > 1 && (
            <>
              <button
                onClick={() =>
                  setImageIndex((prev) =>
                    prev === 0 ? images.length - 1 : prev - 1
                  )
                }
                className="absolute left-2 top-1/2 -translate-y-1/2 rounded-full bg-black/60 px-2 py-1 text-xs text-white"
              >
                ←
              </button>

              <button
                onClick={() =>
                  setImageIndex((prev) =>
                    prev === images.length - 1 ? 0 : prev + 1
                  )
                }
                className="absolute right-2 top-1/2 -translate-y-1/2 rounded-full bg-black/60 px-2 py-1 text-xs text-white"
              >
                →
              </button>

              <div className="absolute bottom-2 right-2 rounded-full bg-black/60 px-2 py-0.5 text-xs text-white">
                {imageIndex + 1}/{images.length}
              </div>
            </>
          )}
        </div>
      ) : (
        <div className="mb-3 flex h-40 w-full items-center justify-center rounded-xl bg-gray-100 text-sm text-gray-400">
          Brak zdjęcia
        </div>
      )}

      <div className="mb-2">
        <h3 className="text-base font-bold text-gray-900">{item.title}</h3>

        <div className="mt-1">
          <ReservationBadge
            status={effectiveStatus}
            reservedUntil={item.reserved_until}
          />
        </div>
      </div>

      {item.description && (
        <p className="mb-3 text-sm text-gray-700">{item.description}</p>
      )}

      <div className="mb-3 flex flex-wrap gap-2 text-xs">
        <span className="rounded-full bg-gray-100 px-2 py-1">
          {item.category}
        </span>

        {item.condition && (
          <span className="rounded-full bg-gray-100 px-2 py-1">
            {item.condition}
          </span>
        )}

        {item.size && (
          <span className="rounded-full bg-gray-100 px-2 py-1">
            {item.size}
          </span>
        )}

        <span className="rounded-full bg-blue-100 px-2 py-1 text-blue-700">
          {Math.round(item.distance_m)} m
        </span>
      </div>

      <div className="flex flex-col gap-2">
        <button
          className="rounded-xl border border-gray-300 px-3 py-2 text-sm font-semibold text-gray-700 transition hover:bg-gray-100 active:scale-95"
          onClick={() => onAddPhoto(item.id)}
        >
          Dodaj zdjęcie
        </button>

        {effectiveStatus === 'active' && (
          <button
            className="rounded-xl bg-green-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-green-700 active:scale-95 disabled:opacity-50"
            disabled={actionLoading || !deviceId}
            onClick={reserveItem}
          >
            {actionLoading ? 'Rezerwuję...' : 'Rezerwuję na 30 min'}
          </button>
        )}

        {isReserved && !isMine && (
          <div className="rounded-xl bg-orange-50 px-3 py-2 text-xs font-medium text-orange-700">
            Ten przedmiot jest chwilowo zarezerwowany.
          </div>
        )}

        {isReserved && isMine && (
          <>
            <button
              className="rounded-xl bg-blue-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-blue-700 active:scale-95 disabled:opacity-50"
              disabled={actionLoading}
              onClick={markAsTaken}
            >
              Odebrane
            </button>

            <button
              className="rounded-xl bg-gray-500 px-3 py-2 text-sm font-semibold text-white transition hover:bg-gray-600 active:scale-95 disabled:opacity-50"
              disabled={actionLoading}
              onClick={cancelReservation}
            >
              Anuluj rezerwację
            </button>
          </>
        )}
      </div>
    </div>
  )
}

export default function ItemsMap() {
  const [items, setItems] = useState<Item[]>([])
  const [loading, setLoading] = useState(true)
  const [uploadItemId, setUploadItemId] = useState<string | null>(null)
  const [selectedItem, setSelectedItem] = useState<Item | null>(null)
  const [onlyWithPhotos, setOnlyWithPhotos] = useState(false)
  const [deviceId, setDeviceId] = useState<string | null>(null)
  const [selectedLocation, setSelectedLocation] =
    useState<[number, number]>(defaultCenter)

  const markerRefs = useRef<Record<string, L.Marker | null>>({})

  const visibleItems = onlyWithPhotos
    ? items.filter((item) => (item.image_urls?.length ?? 0) > 0)
    : items

  async function loadItems() {
    setLoading(true)

    const { data, error } = await supabase.rpc('get_items_nearby', {
      user_lat: defaultCenter[0],
      user_lng: defaultCenter[1],
      radius_m: 3000,
    })

    if (error) {
      console.error(error)
      setLoading(false)
      return
    }

    console.table(
      data?.map((item: Item) => ({
        title: item.title,
        status: item.status,
        reserved_until: item.reserved_until,
        reserved_by: item.reserved_by,
      }))
    )

    setItems(data ?? [])
    setLoading(false)
  }

  useEffect(() => {
    loadItems()
  }, [])

  useEffect(() => {
    let id = localStorage.getItem('device_id')

    if (!id) {
      id = crypto.randomUUID()
      localStorage.setItem('device_id', id)
    }

    setDeviceId(id)
  }, [])

  useEffect(() => {
    if (!selectedItem) return

    const marker = markerRefs.current[selectedItem.id]

    if (marker) {
      setTimeout(() => {
        marker.openPopup()
      }, 400)
    }
  }, [selectedItem])

  return (
    <div className="flex h-screen w-full">
      <div className="w-80 overflow-y-auto border-r bg-white">
        <div className="border-b p-3 font-bold">
          {loading ? 'Ładowanie...' : `Znaleziono: ${visibleItems.length}`}
        </div>

        <label className="flex items-center gap-2 border-b p-3 text-sm">
          <input
            type="checkbox"
            checked={onlyWithPhotos}
            onChange={(e) => setOnlyWithPhotos(e.target.checked)}
          />
          Tylko ze zdjęciem
        </label>

        {visibleItems.map((item) => {
          const img = item.image_urls?.[0]

          const reservationExpired =
            item.status === 'reserved' &&
            isReservationExpired(item.reserved_until)

          const effectiveStatus = reservationExpired ? 'active' : item.status

          return (
            <div
              key={item.id}
              className={`cursor-pointer border-b p-2 hover:bg-gray-100 ${
                selectedItem?.id === item.id ? 'bg-blue-50' : ''
              }`}
              onClick={() => {
                setSelectedItem(item)
                setSelectedLocation([item.latitude, item.longitude])
              }}
            >
              {img ? (
                <img
                  src={img}
                  alt={item.title}
                  className="mb-2 h-24 w-full rounded object-cover"
                />
              ) : (
                <div className="mb-2 flex h-24 w-full items-center justify-center rounded bg-gray-200 text-xs">
                  Brak zdjęcia
                </div>
              )}

              <div className="mb-1 text-sm font-semibold">{item.title}</div>

              <div className="mb-1">
                <ReservationBadge
                  status={effectiveStatus}
                  reservedUntil={item.reserved_until}
                />
              </div>

              <div className="text-xs text-gray-500">
                {Math.round(item.distance_m)} m
              </div>
            </div>
          )
        })}
      </div>

      <div className="relative flex-1">
        <MapContainer
          center={defaultCenter}
          zoom={14}
          className="h-full w-full"
        >
          <TileLayer
            attribution="&copy; OpenStreetMap contributors"
            url="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
          />

          <MapFocusController selectedItem={selectedItem} />

          <MapClickHandler
            onSelect={(lat, lng) => setSelectedLocation([lat, lng])}
          />

          <Marker position={selectedLocation} icon={markerIcon}>
            <Popup>Nowe zgłoszenie tutaj</Popup>
          </Marker>

          {visibleItems.map((item) => {
            const reservationExpired =
              item.status === 'reserved' &&
              isReservationExpired(item.reserved_until)

            const effectiveStatus = reservationExpired ? 'active' : item.status

            return (
              <Marker
                key={item.id}
                position={[item.latitude, item.longitude]}
                icon={createItemIcon(
                  item.image_urls?.[0] ?? null,
                  effectiveStatus
                )}
                ref={(ref) => {
                  markerRefs.current[item.id] = ref
                }}
              >
                <Popup>
                  <ItemPopup
                    item={item}
                    deviceId={deviceId}
                    onAddPhoto={(itemId) => setUploadItemId(itemId)}
                    onRefresh={loadItems}
                  />
                </Popup>
              </Marker>
            )
          })}
        </MapContainer>

        <AddItemForm
          onAdded={loadItems}
          latitude={selectedLocation[0]}
          longitude={selectedLocation[1]}
        />
      </div>

      {uploadItemId && (
        <AddPhotoModal
          itemId={uploadItemId}
          onClose={() => setUploadItemId(null)}
          onUploaded={loadItems}
        />
      )}
    </div>
  )
}
Ważne: ten kod wymaga, żeby istniał plik:

src/lib/reservationTime.ts
z funkcją:

export function isReservationExpired(reservedUntil: string | null): boolean {
  if (!reservedUntil) return true
  return new Date(reservedUntil).getTime() <= Date.now()
}

działa

Dobrze. Teraz aplikacja zaczyna mieć już sensowny „live marketplace feel”:

statusy są czytelne

rezerwacje mają countdown

wygasłe rezerwacje nie blokują UX

lista i mapa są spójne

popup wygląda jak MVP produkcyjne

Następny logiczny krok to już Supabase Realtime.

Cel:

bez refresh

status zmienia się natychmiast u wszystkich

nowe przedmioty pojawiają się live

marker/lista aktualizują się same

To będzie bardzo duży jakościowy skok przy małej ilości kodu.


jedziemy

Teraz dokładamy Supabase Realtime najprostszą wersją: każda zmiana w items odpala loadItems(). To nie jest najbardziej wydajne docelowo, ale jest bezpieczne i dobre dla MVP.

Dodaj w ItemsMap.tsx nowy useEffect pod tym:

useEffect(() => {
  loadItems()
}, [])
Wklej:

useEffect(() => {
  const channel = supabase
    .channel('items-realtime')
    .on(
      'postgres_changes',
      {
        event: '*',
        schema: 'public',
        table: 'items',
      },
      async (payload) => {
        console.log('REALTIME ITEMS CHANGE:', payload)
        await loadItems()
      }
    )
    .subscribe((status) => {
      console.log('REALTIME STATUS:', status)
    })

  return () => {
    supabase.removeChannel(channel)
  }
}, [])
Czyli fragment będzie wyglądał tak:

useEffect(() => {
  loadItems()
}, [])

useEffect(() => {
  const channel = supabase
    .channel('items-realtime')
    .on(
      'postgres_changes',
      {
        event: '*',
        schema: 'public',
        table: 'items',
      },
      async (payload) => {
        console.log('REALTIME ITEMS CHANGE:', payload)
        await loadItems()
      }
    )
    .subscribe((status) => {
      console.log('REALTIME STATUS:', status)
    })

  return () => {
    supabase.removeChannel(channel)
  }
}, [])
Potem w Supabase sprawdź:

Database → Replication → Tables

Dla tabeli items musi być włączone Realtime.

Efekt:

dodasz nowy przedmiot → pojawi się bez ręcznego refresh

zarezerwujesz → lista/mapa się odświeży

oznaczysz jako odebrane → status zaktualizuje się live

inna przeglądarka też zobaczy zmianę

Następny mały krok po tym: realtime także dla item_photos, żeby zdjęcie dodane do przedmiotu pojawiało się od razu.


Gdzieto jest?

Supabase zmienił UI. Nie jest już w tym miejscu.

Wejdź:

Sidebar po lewej:
Database → Publications

Otwórz publikację:
supabase_realtime

Zobaczysz listę tabel.

Włącz:

items

później także item_photos

Czyli:

checkbox / toggle przy tabeli

musi być zaznaczone

Po włączeniu realtime zacznie działać od razu.

Możesz też sprawdzić w konsoli przeglądarki:
powinno pojawić się:

REALTIME STATUS: SUBSCRIBED
a przy zmianach:

REALTIME ITEMS CHANGE:
Jeśli nie działa:

restart npm run dev

upewnij się, że .channel() jest wewnątrz useEffect

sprawdź czy tabela jest w supabase_realtime publication.


Nie rozumiem gdzie powininenem to zobaczyć. W przeglądarce? Gdzie?

Tak — w konsoli developerskiej przeglądarki.

W Chrome:

Kliknij:

F12
albo

Ctrl + Shift + I

Otworzy się panel developerski.

Przejdź do zakładki:
Console

Tam powinieneś zobaczyć:

REALTIME STATUS: SUBSCRIBED
Potem:

dodaj nowy przedmiot

albo kliknij „Anuluj rezerwację”

I powinno pojawić się:

REALTIME ITEMS CHANGE:
z obiektem payload.

Na Twoim screenie jeszcze jedna ważna rzecz:

Realtime już prawdopodobnie działa, bo:

countdown żyje

popup się odświeża poprawnie

Ale żeby potwierdzić:

otwórz drugą kartę przeglądarki

na jednej anuluj rezerwację

na drugiej status powinien zmienić się sam bez refresh.

To jest właściwy test realtime.



Realtime logów jeszcze nie widać.

Widzisz tylko:

console.table(...)
czyli log z loadItems().

To oznacza, że:

albo useEffect realtime się nie wykonał

albo tabela nie jest dodana do supabase_realtime

Sprawdź teraz dokładnie:

1. Czy wkleiłeś TEN kod?
useEffect(() => {
  const channel = supabase
    .channel('items-realtime')
    .on(
      'postgres_changes',
      {
        event: '*',
        schema: 'public',
